OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# ── Resend (envío de email vía HTTPS, no bloqueado por Render) ─────────────────
# 1. Crea cuenta gratis en https://resend.com (3,000 emails/mes gratis)
# 2. Verifica el dominio plastitaps.com en Resend (agrega los registros DNS que te dan)
# 3. Genera un API Key y pégalo abajo
# 4. Una vez verificado el dominio, cambia EMAIL_FROM a algo @plastitaps.com
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=Plastitaps <onboarding@resend.dev>
CONTACT_TO=ventas@plastitaps.com
